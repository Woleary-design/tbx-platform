# Supabase browser/server configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Private admin access. Multiple addresses may be comma-separated.
TBX_ADMIN_EMAILS=owner@example.com

# Optional Atlas import controls
# REBRICKABLE_SETS_URL=https://cdn.rebrickable.com/media/downloads/sets.csv.gz
# REBRICKABLE_THEMES_URL=https://cdn.rebrickable.com/media/downloads/themes.csv.gz
# ATLAS_IMPORT_DRY_RUN=true
# ATLAS_IMPORT_LIMIT=100
